{
  "name": "phasty-server",
  "version": "0.1.1",
  "description": "Fastify dev server with nginx-style try_files routing. Designed primarily for Laravel but usable for other apps.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vasiliishvakin/phasty-server.git"
  },
  "bugs": {
    "url": "https://github.com/vasiliishvakin/phasty-server/issues"
  },
  "homepage": "https://github.com/vasiliishvakin/phasty-server#readme",
  "bin": {
    "phasty": "bin/phasty.js"
  },
  "files": [
    "bin/",
    "src/",
    "stubs/"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "laravel",
    "fastify",
    "dev-server",
    "php",
    "vite",
    "proxy",
    "https"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fastify": "^5",
    "@fastify/static": "^8",
    "@fastify/reply-from": "^12",
    "@fastify/http-proxy": "^10",
    "picocolors": "^1.1",
    "pino": "^9",
    "pino-pretty": "^13",
    "commander": "^13",
    "valibot": "^1"
  },
  "devDependencies": {
    "vitest": "^2.0",
    "@vitest/coverage-v8": "^2.0"
  }
}